# Required in production (stored as GitHub Secrets, injected by deploy.yml)
FLASK_ENV=production
SECRET_KEY=change_me          # generate with: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
DATABASE_URL=sqlite:////home/ubuntu/classroom-chat/backend/instance/prod_users.db

# Optional services
OPENAI_API_KEY=change_me
WEBHOOK_SECRET=change_me

# Dev-only overrides (not needed in production)
# DEV_DATABASE_URI=sqlite:///dev_users.db

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_client_id
COGNITO_CLIENT_SECRET=your_client_secret
COGNITO_DOMAIN=your_cognito_domain.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:5173/api/auth/cognito/callback
COGNITO_REGION=us-east-1